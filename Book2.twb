    <worksheet name='KPI - Drop-off Rate '>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#0035ad'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='British airways cleaned.csv' name='federated.0qj7os00s5qz081g934kt1tfog1x' />
          </datasources>
          <datasource-dependencies datasource='federated.0qj7os00s5qz081g934kt1tfog1x'>
            <column caption='Drop Off Rate' datatype='real' name='[Calculation_0159709108305922]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1 - AVG([booking_complete])' />
            </column>
