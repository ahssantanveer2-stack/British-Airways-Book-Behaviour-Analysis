      <column caption='Drop Off Rate' datatype='real' name='[Calculation_0159709108305922]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - AVG([booking_complete])' />
      </column>
      <column caption='Passenger Groups' datatype='real' name='[Calculation_0159709126078468]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [no_of_passengers] = 1 THEN &quot;Solo&quot;&#13;&#10;ELSEIF [no_of_passengers] = 2 THEN &quot;Couple&quot;&#13;&#10;ELSEIF [no_of_passengers] &lt;= 4 THEN &quot;Small Group&quot;&#13;&#10;ELSE &quot;Large Group&quot;&#13;&#10;END' />
      </column>
